# PostgreSQL database name
POSTGRES_DB=digi2

# PostgreSQL username
POSTGRES_USER=digi2_user

# PostgreSQL password for local development only
POSTGRES_PASSWORD=digi2_password

# Database hostname inside Docker Compose
POSTGRES_HOST=db

# PostgreSQL default port
POSTGRES_PORT=5432

# Django secret key for development only
DJANGO_SECRET_KEY=change-me

# Enable Django debug mode locally
DJANGO_DEBUG=True

# Hosts allowed to access Django locally
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend API URL used by Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# AWS region for later stages
AWS_REGION=us-east-1